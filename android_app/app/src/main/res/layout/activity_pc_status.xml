<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:clipToPadding="false">

    <!-- Container taking 100% height minus padding -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clTopContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvPcError"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TITLE BAR -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PC Status"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/btnPcSettings"/>

        <ImageButton
            android:id="@+id/btnPcSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/titleDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="-16dp"
            android:layout_marginEnd="-16dp"
            android:background="#33888888"
            app:layout_constraintTop_toBottomOf="@id/btnPcSettings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- SYSTEM TRAY (Logos) -->
        <ImageView
            android:id="@+id/ivDesktopEnv"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_computer"
            app:layout_constraintTop_toBottomOf="@id/titleDivider"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/ivSessionState"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="12dp"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_lock_open"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintStart_toEndOf="@id/ivDesktopEnv" />

        <!-- Right aligned elements -->
        <TextView
            android:id="@+id/tvBatteryState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/llBatteryContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintEnd_toStartOf="@id/tvBatteryState">

            <com.elyot.pclink.BatteryIconView
                android:id="@+id/ivBatteryState"
                android:layout_width="32dp"
                android:layout_height="18dp" />

            <LinearLayout
                android:layout_width="23dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="start"
                android:gravity="center_vertical"
                android:layout_marginStart="2dp"
                android:layout_marginTop="2dp">
                
                <View
                    android:id="@+id/vPowerDot1"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@android:color/white" />
                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
                <View
                    android:id="@+id/vPowerDot2"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@android:color/white" />
                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
                <View
                    android:id="@+id/vPowerDot3"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvVolumePct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="--%"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintEnd_toStartOf="@id/llBatteryContainer" />

        <ImageView
            android:id="@+id/ivVolumeTop"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:layout_marginEnd="8dp"
            app:layout_goneMarginEnd="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_volume_up"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintEnd_toStartOf="@id/tvVolumePct" />

        <ImageView
            android:id="@+id/ivBluetooth"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_bluetooth"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintEnd_toStartOf="@id/ivVolumeTop" />

        <ImageView
            android:id="@+id/ivNetwork"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_wifi"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/ivDesktopEnv"
            app:layout_constraintBottom_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintEnd_toStartOf="@id/ivBluetooth" />

        <!-- THICK SEPARATOR -->
        <View
            android:id="@+id/thickSeparator"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_marginTop="24dp"
            android:background="?attr/colorControlNormal"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintTop_toBottomOf="@id/ivDesktopEnv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 2 EQUAL BOXES BELOW SEPARATOR -->
        <LinearLayout
            android:id="@+id/llBoxes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/thickSeparator"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Box 1: Wi-Fi -->
            <LinearLayout
                android:id="@+id/box1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_rounded_box"
                android:orientation="vertical"
                android:padding="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wi-Fi"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp" />
                    <ImageButton
                        android:id="@+id/btnRefreshWifi"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_refresh"
                        android:padding="4dp" />
                </RelativeLayout>
                
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="4dp">
                    <LinearLayout
                        android:id="@+id/llWifiList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvWifiStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:gravity="center"
                            android:textSize="14sp" />
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

            <!-- Box 2: Bluetooth -->
            <LinearLayout
                android:id="@+id/box2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_rounded_box"
                android:orientation="vertical"
                android:padding="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bluetooth"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="8dp" />
                    <ImageButton
                        android:id="@+id/btnRefreshBluetooth"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_refresh"
                        android:padding="4dp" />
                </RelativeLayout>
                
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="4dp">
                    <LinearLayout
                        android:id="@+id/llBluetoothList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvBluetoothStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:gravity="center"
                            android:textSize="14sp" />
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>

            <!-- Box 3: Monitors -->
            <LinearLayout
                android:id="@+id/box3"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_rounded_box"
                android:orientation="vertical"
                android:padding="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monitors"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <ImageButton
                        android:id="@+id/btnMonitorSettings"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/btnRefreshMonitors"
                        android:layout_marginEnd="12dp"/>

                    <ImageButton
                        android:id="@+id/btnRefreshMonitors"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_refresh"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:layout_centerVertical="true"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>
                
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="4dp">
                    <LinearLayout
                        android:id="@+id/llMonitorList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:id="@+id/tvMonitorStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:gravity="center"
                            android:textSize="14sp" />
                    </LinearLayout>
                </ScrollView>
            </LinearLayout>
        </LinearLayout>

        <!-- VERTICAL VOLUME SLIDER -->
        <FrameLayout
            android:id="@+id/flVolumePopup"
            android:layout_width="48dp"
            android:layout_height="200dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_rounded_box"
            app:layout_constraintTop_toBottomOf="@id/ivVolumeTop"
            app:layout_constraintStart_toStartOf="@id/ivVolumeTop"
            app:layout_constraintEnd_toEndOf="@id/ivVolumeTop">

            <SeekBar
                android:id="@+id/sbPcVolumeVertical"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:rotation="270"
                android:max="100" />
        </FrameLayout>

        <!-- VERTICAL POWER POPUP -->
        <LinearLayout
            android:id="@+id/llPowerPopup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="@drawable/bg_rounded_box"
            app:layout_constraintTop_toBottomOf="@id/llBatteryContainer"
            app:layout_constraintStart_toStartOf="@id/llBatteryContainer"
            app:layout_constraintEnd_toEndOf="@id/llBatteryContainer">

            <ImageButton
                android:id="@+id/btnPowerPerformance"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_gnome_performance"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="12dp"/>
                
            <ImageButton
                android:id="@+id/btnPowerBalanced"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_gnome_balanced"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="12dp"/>

            <ImageButton
                android:id="@+id/btnPowerSaver"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_gnome_power_saver"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- NETWORK POPUP -->
        <LinearLayout
            android:id="@+id/llNetworkPopup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginEnd="8dp"
            android:padding="8dp"
            android:background="@drawable/bg_rounded_box"
            app:layout_constraintTop_toTopOf="@id/ivNetwork"
            app:layout_constraintBottom_toBottomOf="@id/ivNetwork"
            app:layout_constraintEnd_toStartOf="@id/ivNetwork">

            <ImageButton
                android:id="@+id/btnNetworkWifiToggle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_gnome_wifi"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Error Text placed below the main container -->
    <TextView
        android:id="@+id/tvPcError"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#D32F2F"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
