<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:clipToPadding="false"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Distant Commands Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center_vertical|start"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="-16dp"
            android:layout_marginEnd="-16dp"
            android:layout_marginBottom="16dp"
            android:background="#33888888" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Display Settings"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buttons per line (1 to 4)" />
        <EditText
            android:id="@+id/editButtonsPerLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="2" />



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Settings Tile Command Slot"
            android:layout_marginTop="4dp" />
        <Spinner
            android:id="@+id/spinnerTileSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Settings Tile Icon (Custom)"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:id="@+id/ivTileCustomIconPreview"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="#E0E0E0"
                android:scaleType="centerInside"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btnPickCustomTileIcon"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Pick Custom Icon" />

            <Button
                android:id="@+id/btnClearCustomTileIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Clear" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Network Default Settings"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default SSH IP / Host" />
        <EditText
            android:id="@+id/editDefaultHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:hint="192.168.1.100" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default SSH Port"
            android:layout_marginTop="4dp"/>
        <EditText
            android:id="@+id/editDefaultPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="22" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default Username"
            android:layout_marginTop="4dp"/>
        <EditText
            android:id="@+id/editDefaultUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textVisiblePassword"
            android:hint="root" />

        <TextView
            android:id="@+id/tvGlobalKeyStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Private Key Loaded"
            android:textColor="#AA0000"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnLoadGlobalKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load Ed25519 Private Key File"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnSaveGlobalSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:layout_marginTop="12dp" />
            
    </LinearLayout>
</ScrollView>
