<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:clipToPadding="false">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Music Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center_vertical|start"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="-16dp"
            android:layout_marginEnd="-16dp"
            android:layout_marginBottom="16dp"
            android:background="#33888888" />

        <CheckBox
            android:id="@+id/cbPersistentNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show persistent notification"
            android:textSize="16sp"
            android:layout_marginTop="4dp" />

        <CheckBox
            android:id="@+id/cbHardwareVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Control PC volume with phone buttons"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#33888888" />

        <!-- Lyrics Delay -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lyrics Offset (ms):"
            android:textSize="16sp"
            android:textStyle="bold" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <Button
                android:id="@+id/btnLyricsMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-" />
            <SeekBar
                android:id="@+id/sbLyricsOffset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="4000" />
            <Button
                android:id="@+id/btnLyricsPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvLyricsOffsetValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="0 ms"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#33888888" />

        <!-- Time Bar Color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time Bar Color (Hex):"
            android:textSize="16sp"
            android:textStyle="bold" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <View
                android:id="@+id/vTimeColorPreview"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:background="#FFFFFF" />
            <EditText
                android:id="@+id/etTimeColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="#FFFFFF"
                android:inputType="text"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Volume Bar Color -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volume Bar Color (Hex):"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <View
                android:id="@+id/vVolColorPreview"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:background="#FFFFFF" />
            <EditText
                android:id="@+id/etVolColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="#FFFFFF"
                android:inputType="text"
                android:maxLines="1" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#33888888" />

        <!-- Polling Interval -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server Sync Interval (ms):"
            android:textSize="16sp"
            android:textStyle="bold" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <Button
                android:id="@+id/btnPollingMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-" />
            <SeekBar
                android:id="@+id/sbPollingInterval"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="4500" />
            <Button
                android:id="@+id/btnPollingPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvPollingIntervalValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="3000 ms"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#33888888" />

        <!-- Rotation Speed -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cover Rotation Speed (RPM):"
            android:textSize="16sp"
            android:textStyle="bold" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <Button
                android:id="@+id/btnRotationMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-" />
            <SeekBar
                android:id="@+id/sbRotationSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100" />
            <Button
                android:id="@+id/btnRotationPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvRotationSpeedValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="33 RPM"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Save Settings" />

    </LinearLayout>
</ScrollView>
