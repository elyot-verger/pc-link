<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/touchpadContainer">

    <!-- Touch Area -->
    <View
        android:id="@+id/touchArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/mouseButtons"
        android:background="#11888888" />

    <!-- Keyboard Button Overlay -->
    <ImageButton
        android:id="@+id/btnOpenKeyboard"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_margin="16dp"
        android:src="@drawable/ic_keyboard"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="?attr/colorControlNormal"
        android:scaleType="centerInside"
        android:alpha="0.5" />

    <!-- Mouse Buttons -->
    <LinearLayout
        android:id="@+id/mouseButtons"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btnLeftClick"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:layout_marginRight="4dp"
            android:backgroundTint="#33888888" />

        <Button
            android:id="@+id/btnMiddleClick"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            android:layout_marginEnd="4dp"
            android:layout_marginRight="4dp"
            android:backgroundTint="#33888888" />

        <Button
            android:id="@+id/btnRightClick"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:backgroundTint="#33888888" />

    </LinearLayout>

</RelativeLayout>
